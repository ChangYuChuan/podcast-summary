# config.yaml.example
#
# Copy this file to ~/.config/psum/<your-name>.yaml (or run `psum init`)
# and fill in your values. Each YAML file under ~/.config/psum/ is an
# independent pipeline — different feeds, schedule, recipients, etc.
#
# This example is modelled on the daily Taiwan stock-podcast digest:
# RSS podcasts + YouTube channels, transcribed in Chinese, with cover
# images generated by gpt-image-2 and posted as an Instagram carousel.
# Strip the parts you don't need.

# Where the project lives. `psum init` autodetects this; only set it
# manually if you cloned the repo somewhere unusual.
project_root: /path/to/podcast-summary

# Where audio / transcripts / reports are stored. Anything under this
# folder is treated as cache — safe to delete.
source_folder: /path/to/psum-data

# ---------------------------------------------------------------------------
# Sources — RSS podcast feeds and YouTube channels in the same list.
#   - For RSS:    just `name` + `url`.
#   - For YouTube: add `type: youtube` (the wizard auto-detects YouTube URLs).
#                  Captions are tried first; videos without captions fall
#                  back to yt-dlp + Whisper.
# ---------------------------------------------------------------------------
feeds:
  # Taiwan stock podcasts (RSS via SoundOn)
  - name: gooaye
    url: https://feeds.soundon.fm/podcasts/954689a5-3096-43a4-a80b-7810b219cef3.xml
  - name: M觀點
    url: https://feeds.soundon.fm/podcasts/b8f5a471-f4f7-4763-9678-65887beda63a.xml

  # YouTube analyst channels
  - name: MarboTV
    url: https://www.youtube.com/@marbotv111
    type: youtube
    language: zh
  - name: 阮慕驊
    url: https://www.youtube.com/@ruanmuhhwa
    type: youtube
    language: zh
  - name: 李蜀芳股市全芳位
    url: https://www.youtube.com/@李蜀芳股市全芳位
    type: youtube
    language: zh

# ---------------------------------------------------------------------------
# Schedule — pair `lookback_days` with `schedule` so runs don't overlap or
# leave gaps. Common patterns:
#   lookback_days: 1  +  schedule: "0 8 * * *"     → daily at 8 AM
#   lookback_days: 3  +  schedule: "0 8 */3 * *"   → every 3 days
#   lookback_days: 7  +  schedule: "0 8 * * 0"     → weekly, Sundays
# ---------------------------------------------------------------------------
lookback_days: 1
schedule: "0 8 * * *"

# Whisper model used to transcribe audio that has no captions.
# tiny / base / small / medium / large / large-v3
# When whisper_language starts with "zh" the report defaults to a
# Traditional-Chinese template that includes a "本期提到的個股" section.
whisper_model: medium
whisper_language: zh

# Title used in the email header, image prompts, and Instagram caption.
report_title: 股市日報

# Prefix used when creating the NotebookLM notebook (date range is appended).
notebooklm_notebook_prefix: 股市日報

# Path to the nlm binary (autodetected from the psum venv if unset).
# nlm_path: /Users/you/.config/psum/venv/bin/nlm

# ---------------------------------------------------------------------------
# Email — set enabled: false to generate the report without emailing it.
# SMTP password is read from EMAIL_SMTP_PASSWORD env var (preferred).
# ---------------------------------------------------------------------------
email:
  enabled: false
  to: ''                     # str or list of strings
  from: ''
  smtp_host: smtp.gmail.com
  smtp_port: 587
  smtp_user: ''
  smtp_password: ''          # leave blank — use EMAIL_SMTP_PASSWORD env var

# Data retention (0 = keep forever).
retention:
  audio_months: 3
  transcripts_months: 3
  reports_months: 3

# ---------------------------------------------------------------------------
# Cover image generation (optional)
# Requires: pip install openai  +  OPENAI_API_KEY env var
#
# One image per report section. With gpt-image-2 the image is base64-only,
# so the pipeline auto-uploads to catbox.moe (no auth) to get a public URL
# for Instagram. dall-e-3 returns a hosted URL directly.
# ---------------------------------------------------------------------------
image_generation:
  enabled: true
  model: gpt-image-2          # or dall-e-3
  size: 1024x1024
  quality: medium             # gpt-image-2: low | medium | high | auto
                              # dall-e-3:    standard | hd
  style: infographic          # infographic (summary card) | illustration (abstract)
  max_images: 10              # cap; one image per report section
  # language: zh              # override (defaults to whisper_language)
  # signature: "ig:your_handle"  # subtle footer on every card (auto-derived from
                                 # instagram.handle when posting is enabled)
  # disclaimer: "Personal notes — not investment advice"
                                 # rendered above the signature in soft grey;
                                 # use this for "not financial advice" copy
  # mascot: "A cute fluffy red toy poodle named Q比 with round eyes …"
                                 # describes a recurring character to render
                                 # in a corner of every card. The model is
                                 # asked to keep its look consistent across
                                 # the carousel.
  # style_base: "..."         # shared visual style for cohesion across cards
  # prompt_template: "..."    # advanced: full prompt override

# ---------------------------------------------------------------------------
# Instagram posting (optional)
# Requires: Instagram Business/Creator account + Facebook App with
#           instagram_content_publish permission + long-lived access token.
# Set INSTAGRAM_ACCESS_TOKEN env var (preferred) or instagram.access_token.
# Caption is built from the report's actual highlights and stocks-mentioned
# section; language follows whisper_language.
# ---------------------------------------------------------------------------
instagram:
  enabled: true
  # user_id is optional — auto-discovered from the token via GET /me.
  # user_id: "1234567890"
  api_version: v21.0
  # language: zh              # override (defaults to whisper_language)
  # caption_template: "..."   # advanced: placeholders {report_title} {date_range}
  # caption_heading_zh: "本期推薦書單"   # custom carousel section heading
  # caption_heading_en: "Books covered"
  # hashtags_zh: "#讀書 #推薦書單 #自我成長"
  # hashtags_en: "#books #reading #weekly"
  # access_token: ""          # prefer INSTAGRAM_ACCESS_TOKEN env var

# ---------------------------------------------------------------------------
# Report mode
#   sections — fixed sections (Episode Summaries / Themes / Stocks / Takeaways).
#   discover — discovers every individual item discussed and produces ONE
#              section per item. Items can be stocks / books / products /
#              destinations / anything — the framing is entirely defined by
#              the prompts you supply below.
# ---------------------------------------------------------------------------
report_mode: discover

# ---------------------------------------------------------------------------
# Prompts — the pipeline reads them straight from here, no code defaults.
#
#   discovery — sent verbatim to NotebookLM. Should ask for a numbered list.
#   detail    — sent once per discovered item. MUST contain {item} placeholder.
#   image     — sent once per section to the image model. Supported placeholders:
#                 {report_title}  {date_range}  {section_title}  {card_label}
#                 {idx}  {total}  {highlights}  {themes}
#                 {mascot}        — image_generation.mascot
#                 {disclaimer}    — image_generation.disclaimer
#                 {signature}     — image_generation.signature
#               If you don't want a mascot/disclaimer/signature on the card,
#               clear the corresponding `image_generation` field AND remove
#               the matching block from this template.
#
# To re-target the digest (e.g. books, news, products), rewrite all three
# prompts here — no code changes needed.
# ---------------------------------------------------------------------------
prompts:
  discovery: |
    請列出資料來源中所有被討論到的個股、ETF 或公司，範圍包含台股、美股、港股，
    以及指數型 / 主題型 ETF。
    格式要求：(1) 每一檔獨立成行，使用「1. Intel (INTC)」、「2. 台積電 (2330)」
    這種編號 + 名稱 + 括號內代號的格式；(2) 同一檔股票只列一次，依資料中討論的份量
    由多到少排序；(3) 只列出實際被分析或評論的標的，不要憑空產生；(4) 至多列出 12 檔。
    請務必保持來源中性：不要提及任何 podcast、YouTube 頻道、節目名稱、主持人或來賓的名字。
    請使用繁體中文回答。回答中只需列出個股清單，不要附加說明文字。

  detail: |
    請針對「{item}」這一檔股票，整理出一份客觀、中立的個股筆記。
    請涵蓋以下五個面向，每一項使用獨立的項目符號（• 開頭），且每一個重點都必須是完整、自包含的句子：
      • 公司近況、基本面與營運重點、技術面 / 籌碼面、風險、關鍵數字或近期催化劑。

    嚴禁出現「看多 / 看空 / 中性 / 觀察 / 看好 / 不看好 / 建議買進 / 目標價 / 逢低買進」
    這類帶有評價或操作意涵的字眼。請務必保持來源中性，不要提及任何 podcast、YouTube
    頻道、節目名稱、主持人或來賓的名字。答覆中不要保留 [1] / [1-3] 引用標記。
    請使用繁體中文回答。

  image: |
    請為《{report_title}》（{date_range}）設計一張 Instagram 資訊卡片。
    段落主題：{section_title}

    請完整地呈現以下重點作為卡片主要內容（全部使用繁體中文）：
    {highlights}

    視覺風格：簡潔可愛的 Instagram 資訊卡片，方形 1:1 構圖，淡藍 / 奶油白背景，
    深藍色（#1F4F7A）的標題與內文。

    吉祥物：在卡片角落放一個小小的吉祥物 — {mascot}。整組卡片中造型、顏色必須一致。

    卡片底部依序放置：
      1) 免責聲明「{disclaimer}」 — 小字、柔和中性灰、置中對齊。
      2) 簽名「{signature}」 — 更小字、淡藍或柔和灰色。

    嚴禁在卡片上出現任何 podcast、YouTube、節目、頻道或主持人的名稱。

# ---------------------------------------------------------------------------
# Custom report sections (optional, ignored when report_mode: stocks)
# Each section is queried independently against the NotebookLM notebook.
# If omitted, a built-in 4-section template is used: Chinese when
# whisper_language is "zh", otherwise English. Both built-in templates
# include a "Stocks Mentioned / 本期提到的個股" section.
# ---------------------------------------------------------------------------
# report_sections:
#   - title: "Section Title"
#     prompt: "The question / prompt to send to NotebookLM for this section"
