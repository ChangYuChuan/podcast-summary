# config.yaml.example
#
# This is the working configuration that ships as the default example —
# a daily Traditional-Chinese stock digest built from RSS podcasts and
# YouTube channels, with one Instagram carousel card per discovered stock.
#
# Copy to ~/.config/psum/<your-name>.yaml (or run `psum init`), then
# replace the few personal placeholders marked with /path/to/ or
# your_handle. Everything else (feeds, prompts, image style, schedule)
# is meant to be edited freely — that's the point of having it in config.

project_root: /path/to/podcast-summary
source_folder: /path/to/psum-data

# ---------------------------------------------------------------------------
# Sources — mix RSS podcasts and YouTube channels in one list.
#   RSS feeds:        name + url.
#   YouTube channels: also `type: youtube` (auto-detected by the wizard).
#                     Captions are tried first; videos without captions fall
#                     back to yt-dlp + Whisper.
# ---------------------------------------------------------------------------
feeds:
  - name: gooaye
    url: https://feeds.soundon.fm/podcasts/954689a5-3096-43a4-a80b-7810b219cef3.xml
  - name: M觀點
    url: https://feeds.soundon.fm/podcasts/b8f5a471-f4f7-4763-9678-65887beda63a.xml
  - name: MarboTV
    url: https://www.youtube.com/@marbotv111
    type: youtube
    language: zh
  - name: 阮慕驊
    url: https://www.youtube.com/@ruanmuhhwa
    type: youtube
    language: zh
  - name: 李蜀芳股市全芳位
    url: https://www.youtube.com/@李蜀芳股市全芳位
    type: youtube
    language: zh

# Schedule — pair lookback_days with the cron interval so runs don't
# overlap or leave gaps.
#   1d + "0 8 * * *"     daily at 08:00
#   3d + "0 8 */3 * *"   every 3 days at 08:00
#   7d + "0 8 * * 0"     weekly on Sunday at 08:00
lookback_days: 1
schedule: 0 20 * * *

# Whisper transcription (only used when YouTube captions aren't available).
whisper_model: medium       # tiny / base / small / medium / large / large-v3
whisper_language: zh

notebooklm_notebook_prefix: 股市日報
nlm_path: /path/to/.config/psum/venv/bin/nlm    # autodetected by `psum init`
report_title: 股市日報

# ---------------------------------------------------------------------------
# Report mode
#   sections — fixed sections (Episode Summaries / Themes / Stocks / Takeaways).
#   discover — discovers every individual item discussed and produces ONE
#              section per item, capped at image_generation.max_images
#              (Instagram's carousel limit is 10).
# ---------------------------------------------------------------------------
report_mode: discover

# ---------------------------------------------------------------------------
# All NotebookLM and image prompts live here. Edit freely — there are no
# code defaults. To re-target the digest (books, news, products) rewrite
# the three blocks below; nothing in code changes.
#
#   discovery — sent verbatim to NotebookLM. Should ask for a numbered list.
#   detail    — sent once per discovered item. MUST contain {item} placeholder.
#   image     — sent once per section to the image model. Supported placeholders:
#                 {report_title}  {date_range}  {section_title}  {card_label}
#                 {idx}  {total}  {highlights}  {themes}
#                 {mascot}  {disclaimer}  {signature}   (sourced from image_generation.*)
# ---------------------------------------------------------------------------
prompts:
  discovery: |
    請列出資料來源中所有被討論到的個股、ETF 或公司，範圍包含台股、美股、港股，以及指數型 / 主題型 ETF。
    格式要求：  (1) 每一檔獨立成行，使用「1. Intel (INTC)」、「2. 台積電 (2330)」這種編號 + 中文 / 英文名稱 + 括號內代號的格式；  (2) 同一檔股票只列一次，依資料中討論的份量由多到少排序；  (3) 只列出實際被分析或評論的標的，不要憑空產生；  (4) 至多列出 12 檔。
    請務必保持來源中性：不要提及任何 podcast、YouTube 頻道、節目名稱、集數編號、主持人或來賓的名字。請使用「資料來源」、「本期內容」這類中性詞彙，也不要寫「在 XX 節目中提到」這種句式。
    請使用繁體中文回答。回答中只需列出個股清單，不要附加說明文字。

  detail: |
    請針對「{item}」這一檔股票，根據資料來源中所有相關的討論，整理出一份客觀、中立的個股筆記。
    請涵蓋以下五個面向，每一項使用獨立的項目符號（• 開頭），且每一個重點都必須是完整、自包含的句子：
      • 公司近況：用一兩句話說明資料來源在本期討論到這檔個股的背景或起因（例如最新事件、新品、財報、產業變化）。
      • 基本面與營運重點：3–5 點，例如業務進展、產品線、訂單能見度、毛利、研發進度等可驗證的事實。
      • 技術面 / 籌碼面：1–3 點，若資料中有提到價量、外資 / 投信動向、技術指標等。
      • 風險與需要關注的因素：1–3 點，包含產業風險、競爭、政策、總體環境等中性描述的不確定性。
      • 關鍵數字或近期催化劑：列出具體的數據、日期、價位、財報時點等資訊；若資料來源中沒有具體數字，請寫「資料來源未提供具體數字」。

    重要：本筆記為客觀整理，**不要**寫出主觀的投資建議或定調，嚴禁出現「看多」、「看空」、「中性」、「觀察」、「看好」、「不看好」、「建議買進」、「建議賣出」、「進場」、「出場」、「目標價」、「值得布局」、「逢低買進」這類帶有評價或操作意涵的字眼。如果資料來源中出現這類字眼，請改寫成中性的事實陳述（例如把「看好 Intel 轉型」改寫為「Intel 推進 IDM 2.0 策略，並擴大 18A 製程產能」）。
    請務必保持來源中性：不要提及任何 podcast、YouTube 頻道、節目名稱、集數編號、主持人或來賓的名字。請使用「資料來源」、「本期內容」這類中性詞彙，也不要寫「在 XX 節目中提到」這種句式。
    請以直接陳述事實的方式撰寫，不要使用「主持人認為」、「節目中提到」、「他們建議」這類轉述語句。答覆中不要保留 [1]、[1-3] 這類引用標記，也不要在重點中以「主因在於...」或「主要原因是...」這類沒有結尾的片段結束。請使用繁體中文回答。

  image: |
    請為《{report_title}》（{date_range}）設計一張 Instagram 資訊卡片。
    （{card_label}）段落主題：{section_title}

    請完整且清楚地呈現以下重點作為卡片主要內容（請逐條列出，全部使用繁體中文）：
    {highlights}

    視覺風格：簡潔可愛的 Instagram 資訊卡片，方形 1:1 構圖。背景使用淡藍色（如 #DCEEFB / #BFE0F8 / 天空藍）或奶油白漸層，搭配深藍色（#1F4F7A）的標題與內文，重點處可以用一點粉藍或薄荷綠點綴，整體風格乾淨、可愛、討喜。邊距留白寬鬆，使用清晰、現代的繁體中文無襯線字型（例如思源黑體 / Noto Sans TC）。嚴禁出現任何簡體中文字，所有字皆需為繁體中文。**背景與整體版面**請避免使用紅色 / 黃色 / 黑色等高飽和或對比過強的配色，但若插畫角色（例如吉祥物）本身的固有毛色 / 膚色就是紅棕色或暖色系，請依角色的設定如實繪製，不受此限制。

    排版：段落標題以粗體放在卡片頂部，每一個重點獨立成一行，字體在手機上要清晰易讀；不要使用裝飾性元素干擾文字閱讀，留白要充足。

    吉祥物：在卡片角落放一個小小的吉祥物角色 — {mascot}。請以可愛、友善的扁平卡通風格繪製，比例約佔卡片邊長的 12–18%，位置可放在右上、左上或角落空白處（不要遮住主要文字）。整組卡片中，這個吉祥物的造型、顏色、姿態風格必須**完全一致**，讓所有卡片看起來像同一個角色出演的系列。

    卡片底部依序放置以下兩行：
      1) 免責聲明「{disclaimer}」 — 使用比內文小的字體，顏色為柔和的中性灰，置中對齊，僅作為提醒，不要搶主視覺的焦點。
      2) 簽名「{signature}」 — 字體比免責聲明再小一點，使用淡藍色或柔和的灰色，置中或靠右對齊。

    重要：所有文字必須是正確的繁體中文（不可出現簡體字、亂碼、英文亂譯）。
    嚴禁在卡片上出現任何 podcast、YouTube、節目、頻道、集數、主持人或來賓的名稱。

# Email — set enabled: false to skip the email stage entirely.
# SMTP password is read from EMAIL_SMTP_PASSWORD env var (preferred over
# inlining smtp_password here).
email:
  enabled: false
  to: ''
  from: ''
  smtp_host: smtp.gmail.com
  smtp_port: 587
  smtp_user: ''
  smtp_password: ''

# Data retention. 0 = keep forever.
retention:
  audio_months: 3
  transcripts_months: 3
  reports_months: 3

# ---------------------------------------------------------------------------
# Cover image generation (OpenAI)
# Requires OPENAI_API_KEY in ~/.zshenv. With gpt-image-2 (base64-only),
# images are uploaded to tmpfiles.org / catbox.moe to give Instagram a
# fetchable URL — see the host fallback chain in generate_image.py.
# ---------------------------------------------------------------------------
image_generation:
  enabled: true
  model: gpt-image-2          # or dall-e-3
  size: 1024x1024
  quality: medium             # gpt-image-2: low | medium | high | auto
                              # dall-e-3:    standard | hd
  style: infographic
  max_images: 10              # cap; one image per report section
  signature: ig:your_handle
  disclaimer: 筆記觀點分享 非投資建議 請自行判斷
  # mascot — described in plain language; the same character is asked for on every card
  # so the carousel reads as a consistent series. Replace with your own pet / icon.
  mascot: |
    一隻可愛、毛茸茸的卡通寵物角色 (例如柴犬、貴賓狗、貓咪)，圓圓的大眼睛，表情友善溫柔，
    柔和的扁平卡通風格，與卡片淡藍 / 奶油白色調搭配。每張卡片中角色的造型、毛色、五官比例
    必須完全一致。

# ---------------------------------------------------------------------------
# Instagram posting (optional)
# Requires INSTAGRAM_ACCESS_TOKEN in ~/.zshenv. user_id is auto-discovered
# from the token via GET /me, so usually no need to set it.
# ---------------------------------------------------------------------------
instagram:
  enabled: true
  # user_id: '1234567890123456'   # optional — auto-discovered from the token
  api_version: v21.0
  caption_heading_zh: 本期重點個股
  hashtags_zh: '#股市 #投資 #台股 #美股 #個股分析 #財經'
